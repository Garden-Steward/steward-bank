# --- Strapi core ---
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified

# Logical environment label (e.g. test, stg, prod). Used for cron/SMS behavior.
ENVIRONMENT=development

# --- Database (PostgreSQL; see config/database.js) ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# --- Frontend (links in emails, etc.) ---
GARDENVUE_URL=http://localhost:3030

# --- Email (Resend — see config/plugins.js) ---
RESEND_API_KEY=
# Optional override for verification / transactional from-address
SMTP_FROM=noreply@steward.garden

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 sender number, e.g. +15551234567
TWILIONUM=

# --- OpenWeather (see config/helpers/weather.js) ---
WEATHER_API=

# --- Google Maps (batch map features — see config/helpers/mapping.js) ---
GOOGLE_MAP_ID=
GOOGLE_MAPS_API_KEY=

# --- Google Cloud Storage uploads (JSON service account key string — see config/plugins.js) ---
# Paste the full service account JSON on one line, or inject via your host’s secret manager.
GOOGLE_CLOUD_CREDENTIALS=

# --- Google OAuth (Google Photos — see src/api/google-photos/services/google-photos.js) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:1337/api/google-photos/oauth-callback

# --- Mailchimp (list subscribe — see src/api/message/controllers/SmsHelper.js) ---
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=

# --- Sentry (optional; see instrument.js) ---
SENTRY_DSN=
# Optional. Performance sampling 0.0–1.0 (default 1.0).
# SENTRY_TRACES_SAMPLE_RATE=0.2

# --- Scripts (e.g. scripts/updateUsers.js) ---
# Strapi API base URL and personal access token for maintenance scripts
API_URL=http://localhost:1337
SCRIPT_TOKEN=

# --- Tests only (see tests/general/twilio.js; names differ from production TWILIO_* above) ---
# ACCOUNT_SID=
# AUTH_TOKEN=
# TWILIO_SID=
# OUTBOUND_PHONE_NUMBER=
