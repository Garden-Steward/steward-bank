{
  "kind": "collectionType",
  "collectionName": "sms_campaigns",
  "info": {
    "singularName": "sms-campaign",
    "pluralName": "sms-campaigns",
    "displayName": "SMS Campaign",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "volunteer_day": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::volunteer-day.volunteer-day",
      "inversedBy": "sms_campaigns"
    },
    "sent": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "confirmed": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "denied": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "body": {
      "type": "text"
    },
    "garden": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::garden.garden"
    },
    "sender": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "basic",
        "rsvp",
        "survey",
        "volunteer-day",
        "recurring-task",
        "poll"
      ]
    },
    "alert": {
      "type": "boolean"
    },
    "poll_options": {
      "type": "json"
    },
    "closes_at": {
      "type": "datetime"
    },
    "option_a": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "option_b": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "option_c": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "option_d": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user"
    },
    "winner": {
      "type": "string"
    },
    "send_reminder": {
      "type": "boolean",
      "default": true
    },
    "reminder_sent": {
      "type": "boolean",
      "default": false
    }
  }
}
